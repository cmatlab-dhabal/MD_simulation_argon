#
# All the atoms from diferent molecules will be separated at least 2.0
# Anstroms at the solution.
tolerance 2.0

# The file type of input and output files is PDB
filetype pdb

# The name of the output file
output argon.pdb

# 512 argon  atomswill be put in a box
# defined by the minimum coordinates x, y and z = 0. 0. 0. and maximum
# coordinates 20. 20. 20. That is, they will be put in a cube of side 40.

structure Ar.pdb 
  number 512 
  inside box 0. 0. 0. 20. 20. 20. 
end structure


